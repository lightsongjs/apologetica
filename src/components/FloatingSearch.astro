---
import { getCollection } from 'astro:content';

const conversations = await getCollection('conversations');
const teme = await getCollection('teme');
const personalitati = await getCollection('personalitati');
const locuri = await getCollection('locuri');

const denominationLabels: Record<string, string> = {
  'atheist': 'Ateu',
  'baptist': 'Baptist',
  'martorii-lui-iehova': 'Martor al lui Iehova',
};
---

<!-- Hidden trigger button for search overlay (used by header search icon) -->
<button
  id="floating-search-btn"
  class="hidden"
  aria-label="Căutare rapidă"
  style="display: none;"
>
</button>

<!-- Full-Page Search Overlay -->
<div
  id="search-overlay"
  class="fixed inset-0 z-50 hidden"
  style="opacity: 0;"
>
  <!-- Backdrop with blur -->
  <div class="absolute inset-0 bg-gradient-to-br from-amber-50/95 via-white/95 to-blue-50/95 backdrop-blur-xl"></div>

  <!-- Close Button -->
  <button
    id="close-search-btn"
    class="absolute top-6 right-6 z-10 w-12 h-12 flex items-center justify-center rounded-full bg-white/80 hover:bg-white shadow-lg hover:shadow-xl transition-all duration-300 group backdrop-blur-sm border border-gray-100"
    aria-label="Închide căutarea"
  >
    <span class="material-symbols-outlined text-xl text-gray-700 group-hover:text-primary transition-colors">close</span>
  </button>

  <!-- Search Container -->
  <div class="relative h-full overflow-y-auto">
    <div class="max-w-4xl mx-auto px-6 py-12 md:py-20">

      <!-- Search Header -->
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-3 mb-6 opacity-0" id="search-header" style="animation: fadeSlideIn 0.6s ease-out 0.1s forwards;">
          <span class="material-symbols-outlined text-5xl text-primary">auto_stories</span>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900" style="font-family: 'Literata', serif;">Bibliotecă</h1>
        </div>

        <!-- Search Input -->
        <div class="relative max-w-2xl mx-auto opacity-0" id="search-input-container" style="animation: fadeSlideIn 0.6s ease-out 0.2s forwards;">
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-6 flex items-center pointer-events-none">
              <span class="material-symbols-outlined text-3xl text-primary/40">search</span>
            </div>
            <input
              id="search-input"
              type="text"
              placeholder="Caută conversații, teme, personalități..."
              class="w-full pl-16 pr-24 py-6 text-xl bg-white border-2 border-gray-200 rounded-2xl shadow-xl focus:border-primary focus:ring-4 focus:ring-primary/10 focus:outline-none transition-all placeholder:text-gray-400"
              autocomplete="off"
              autofocus
            />
            <div class="absolute inset-y-0 right-0 pr-6 flex items-center pointer-events-none">
              <kbd class="hidden md:inline-flex items-center gap-1 px-3 py-1.5 text-xs font-semibold text-gray-500 bg-gray-100 border border-gray-200 rounded-lg">
                <span class="text-base">⎋</span> ESC
              </kbd>
            </div>
          </div>

          <!-- Search Hint -->
          <p class="mt-4 text-sm text-gray-500 italic" id="search-hint">
            Scrie pentru a căuta prin toată biblioteca...
          </p>
        </div>

        <!-- Keyboard Shortcut Hint -->
        <div class="mt-8 opacity-0" style="animation: fadeSlideIn 0.6s ease-out 0.3s forwards;">
          <p class="text-xs text-gray-400 font-medium tracking-wide">
            Apasă <kbd class="px-2 py-1 text-xs bg-white border border-gray-200 rounded shadow-sm">/</kbd> pentru a deschide căutarea
          </p>
        </div>
      </div>

      <!-- Results Container -->
      <div id="results-container" class="space-y-8 hidden">

        <!-- Conversations Section -->
        <section id="conversations-section" class="hidden">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-2xl text-primary">forum</span>
              <h2 class="text-xl font-bold text-gray-900" style="font-family: 'Literata', serif;">Conversații</h2>
            </div>
            <span id="conversations-count" class="px-3 py-1 text-sm font-bold text-primary bg-primary/10 rounded-full"></span>
          </div>
          <div id="conversations-results" class="grid gap-3"></div>
          <button id="show-more-conversations" class="hidden w-full mt-4 px-6 py-3 text-sm font-semibold text-primary hover:bg-primary/5 rounded-xl transition-all">
            Vezi toate rezultatele →
          </button>
        </section>

        <!-- Teme Section -->
        <section id="teme-section" class="hidden">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-2xl text-primary">auto_stories</span>
              <h2 class="text-xl font-bold text-gray-900" style="font-family: 'Literata', serif;">Teme</h2>
            </div>
            <span id="teme-count" class="px-3 py-1 text-sm font-bold text-primary bg-primary/10 rounded-full"></span>
          </div>
          <div id="teme-results" class="grid gap-3"></div>
          <button id="show-more-teme" class="hidden w-full mt-4 px-6 py-3 text-sm font-semibold text-primary hover:bg-primary/5 rounded-xl transition-all">
            Vezi toate rezultatele →
          </button>
        </section>

        <!-- Personalitati Section -->
        <section id="personalitati-section" class="hidden">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-2xl text-primary">person_pin</span>
              <h2 class="text-xl font-bold text-gray-900" style="font-family: 'Literata', serif;">Personalități</h2>
            </div>
            <span id="personalitati-count" class="px-3 py-1 text-sm font-bold text-primary bg-primary/10 rounded-full"></span>
          </div>
          <div id="personalitati-results" class="grid gap-3"></div>
          <button id="show-more-personalitati" class="hidden w-full mt-4 px-6 py-3 text-sm font-semibold text-primary hover:bg-primary/5 rounded-xl transition-all">
            Vezi toate rezultatele →
          </button>
        </section>

        <!-- Locuri Section -->
        <section id="locuri-section" class="hidden">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-2xl text-primary">location_on</span>
              <h2 class="text-xl font-bold text-gray-900" style="font-family: 'Literata', serif;">Locuri Biblice</h2>
            </div>
            <span id="locuri-count" class="px-3 py-1 text-sm font-bold text-primary bg-primary/10 rounded-full"></span>
          </div>
          <div id="locuri-results" class="grid gap-3"></div>
          <button id="show-more-locuri" class="hidden w-full mt-4 px-6 py-3 text-sm font-semibold text-primary hover:bg-primary/5 rounded-xl transition-all">
            Vezi toate rezultatele →
          </button>
        </section>

      </div>

      <!-- No Results State -->
      <div id="no-results" class="hidden text-center py-16 opacity-0" style="animation: fadeSlideIn 0.4s ease-out forwards;">
        <div class="inline-flex items-center justify-center w-20 h-20 mb-6 bg-gray-100 rounded-full">
          <span class="material-symbols-outlined text-4xl text-gray-400">search_off</span>
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-2" style="font-family: 'Literata', serif;">Niciun rezultat</h3>
        <p class="text-gray-600">Încearcă cu alte cuvinte cheie</p>
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="text-center py-12 space-y-6 opacity-0" style="animation: fadeSlideIn 0.6s ease-out 0.4s forwards;">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-2xl mx-auto">
          <div class="group cursor-pointer suggestion-pill" data-query="Sfânta Treime">
            <div class="p-6 bg-white rounded-2xl shadow-lg hover:shadow-xl transition-all border border-gray-100 hover:border-primary/30">
              <span class="material-symbols-outlined text-3xl text-primary mb-2 block">auto_stories</span>
              <p class="text-sm font-semibold text-gray-900">Sfânta Treime</p>
            </div>
          </div>
          <div class="group cursor-pointer suggestion-pill" data-query="Iisus Hristos">
            <div class="p-6 bg-white rounded-2xl shadow-lg hover:shadow-xl transition-all border border-gray-100 hover:border-primary/30">
              <span class="material-symbols-outlined text-3xl text-primary mb-2 block">person_pin</span>
              <p class="text-sm font-semibold text-gray-900">Iisus Hristos</p>
            </div>
          </div>
          <div class="group cursor-pointer suggestion-pill" data-query="Pocăință">
            <div class="p-6 bg-white rounded-2xl shadow-lg hover:shadow-xl transition-all border border-gray-100 hover:border-primary/30">
              <span class="material-symbols-outlined text-3xl text-primary mb-2 block">favorite</span>
              <p class="text-sm font-semibold text-gray-900">Pocăință</p>
            </div>
          </div>
          <div class="group cursor-pointer suggestion-pill" data-query="Ierusalim">
            <div class="p-6 bg-white rounded-2xl shadow-lg hover:shadow-xl transition-all border border-gray-100 hover:border-primary/30">
              <span class="material-symbols-outlined text-3xl text-primary mb-2 block">location_on</span>
              <p class="text-sm font-semibold text-gray-900">Ierusalim</p>
            </div>
          </div>
        </div>
        <p class="text-sm text-gray-500">Sau începe să scrii pentru a căuta...</p>
      </div>

    </div>
  </div>
</div>

<style>
  @keyframes fadeSlideIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes scaleIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .result-card {
    animation: scaleIn 0.3s ease-out both;
  }

  .result-card:nth-child(1) { animation-delay: 0.05s; }
  .result-card:nth-child(2) { animation-delay: 0.10s; }
  .result-card:nth-child(3) { animation-delay: 0.15s; }
  .result-card:nth-child(4) { animation-delay: 0.20s; }
  .result-card:nth-child(5) { animation-delay: 0.25s; }
  .result-card:nth-child(n+6) { animation-delay: 0.30s; }

  #search-overlay {
    transition: opacity 0.3s ease-out;
  }

  #search-overlay.active {
    opacity: 1 !important;
  }
</style>

<script define:vars={{ conversations, teme, personalitati, locuri, denominationLabels }}>
  const floatingBtn = document.getElementById('floating-search-btn');
  const overlay = document.getElementById('search-overlay');
  const closeBtn = document.getElementById('close-search-btn');
  const searchInput = document.getElementById('search-input');
  const searchHint = document.getElementById('search-hint');
  const resultsContainer = document.getElementById('results-container');
  const emptyState = document.getElementById('empty-state');
  const noResults = document.getElementById('no-results');

  const conversationsSection = document.getElementById('conversations-section');
  const conversationsResults = document.getElementById('conversations-results');
  const conversationsCount = document.getElementById('conversations-count');
  const showMoreConversationsBtn = document.getElementById('show-more-conversations');

  const temeSection = document.getElementById('teme-section');
  const temeResults = document.getElementById('teme-results');
  const temeCount = document.getElementById('teme-count');
  const showMoreTemeBtn = document.getElementById('show-more-teme');

  const personalitatiSection = document.getElementById('personalitati-section');
  const personalitatiResults = document.getElementById('personalitati-results');
  const personalitatiCount = document.getElementById('personalitati-count');
  const showMorePersonalitatiBtn = document.getElementById('show-more-personalitati');

  const locuriSection = document.getElementById('locuri-section');
  const locuriResults = document.getElementById('locuri-results');
  const locuriCount = document.getElementById('locuri-count');
  const showMoreLocuriBtn = document.getElementById('show-more-locuri');

  const PREVIEW_LIMIT = 5;
  let isExpanded = false;
  let fullResults = {
    conversations: [],
    teme: [],
    personalitati: [],
    locuri: []
  };

  // Open overlay
  function openSearch() {
    document.body.style.overflow = 'hidden';
    overlay.classList.remove('hidden');
    setTimeout(() => {
      overlay.classList.add('active');
      searchInput.focus();
    }, 10);
  }

  // Close overlay
  function closeSearch() {
    overlay.classList.remove('active');
    document.body.style.overflow = '';

    setTimeout(() => {
      overlay.classList.add('hidden');
      searchInput.value = '';
      resultsContainer.classList.add('hidden');
      emptyState.classList.remove('hidden');
      noResults.classList.add('hidden');
      searchHint.textContent = 'Scrie pentru a căuta prin toată biblioteca...';
      isExpanded = false;
    }, 300);
  }

  // Event listeners
  floatingBtn?.addEventListener('click', openSearch);
  closeBtn?.addEventListener('click', closeSearch);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeSearch();
  });

  // Keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    // "/" to open
    if (e.key === '/' && !overlay.classList.contains('active')) {
      e.preventDefault();
      openSearch();
    }
    // ESC to close
    if (e.key === 'Escape' && overlay.classList.contains('active')) {
      closeSearch();
    }
  });

  // Suggestion pills
  const suggestionPills = document.querySelectorAll('.suggestion-pill');
  suggestionPills.forEach(pill => {
    pill.addEventListener('click', () => {
      const query = pill.getAttribute('data-query');
      searchInput.value = query;
      searchInput.dispatchEvent(new Event('input'));
      searchInput.focus();
    });
  });

  // Search utilities
  function removeDiacritics(str) {
    return str
      .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
      .replace(/ș/g, 's').replace(/ț/g, 't')
      .replace(/Ă/g, 'A').replace(/Â/g, 'A').replace(/Î/g, 'I')
      .replace(/Ș/g, 'S').replace(/Ț/g, 'T');
  }

  function matchesAtWordBoundary(text, query) {
    if (!query) return false;
    const normalizedText = removeDiacritics(text.toLowerCase());
    const normalizedQuery = removeDiacritics(query.toLowerCase());
    const wordBoundaryRegex = new RegExp(`(^|\\s|[^\\p{L}])${normalizedQuery}`, 'iu');
    return wordBoundaryRegex.test(normalizedText);
  }

  function highlightMatch(text, query) {
    if (!query) return text;
    const normalizedQuery = removeDiacritics(query.toLowerCase());
    let pattern = '';
    for (let char of normalizedQuery) {
      if (char === 'a') pattern += '[aăâĂÂ]';
      else if (char === 'i') pattern += '[iîÎ]';
      else if (char === 's') pattern += '[sșŞ]';
      else if (char === 't') pattern += '[tțŢ]';
      else pattern += char.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }
    const regex = new RegExp(`(${pattern})`, 'gi');
    return text.replace(regex, '<mark class="bg-primary/20 text-primary font-bold px-1 rounded">$1</mark>');
  }

  // Perform search
  function performSearch(query) {
    const originalQuery = query.trim();
    query = removeDiacritics(query.toLowerCase().trim());

    if (!query) {
      resultsContainer.classList.add('hidden');
      emptyState.classList.remove('hidden');
      noResults.classList.add('hidden');
      searchHint.textContent = 'Scrie pentru a căuta prin toată biblioteca...';
      return;
    }

    emptyState.classList.add('hidden');
    searchHint.textContent = `Se caută: "${originalQuery}"`;

    // Search with scoring
    fullResults.conversations = conversations
      .map(conv => {
        let score = 0;
        if (matchesAtWordBoundary(conv.data.title, query)) score += 100;
        if (matchesAtWordBoundary(conv.data.denomination, query)) score += 50;
        if (matchesAtWordBoundary(denominationLabels[conv.data.denomination] || '', query)) score += 50;
        return { item: conv, score };
      })
      .filter(result => result.score > 0)
      .sort((a, b) => b.score - a.score)
      .map(result => result.item);

    fullResults.teme = teme
      .map(tema => {
        let score = 0;
        if (matchesAtWordBoundary(tema.data.title, query)) score += 100;
        if (matchesAtWordBoundary(tema.data.summary, query)) score += 50;
        return { item: tema, score };
      })
      .filter(result => result.score > 0)
      .sort((a, b) => b.score - a.score)
      .map(result => result.item);

    fullResults.personalitati = personalitati
      .map(pers => {
        let score = 0;
        if (matchesAtWordBoundary(pers.data.name, query)) score += 100;
        if (matchesAtWordBoundary(pers.data.title, query)) score += 50;
        return { item: pers, score };
      })
      .filter(result => result.score > 0)
      .sort((a, b) => b.score - a.score)
      .map(result => result.item);

    fullResults.locuri = locuri
      .map(loc => {
        let score = 0;
        if (matchesAtWordBoundary(loc.data.name, query)) score += 100;
        if (matchesAtWordBoundary(loc.data.title, query)) score += 50;
        return { item: loc, score };
      })
      .filter(result => result.score > 0)
      .sort((a, b) => b.score - a.score)
      .map(result => result.item);

    const totalResults = fullResults.conversations.length + fullResults.teme.length +
                         fullResults.personalitati.length + fullResults.locuri.length;

    if (totalResults === 0) {
      resultsContainer.classList.add('hidden');
      noResults.classList.remove('hidden');
      return;
    }

    noResults.classList.add('hidden');
    resultsContainer.classList.remove('hidden');
    renderResults(originalQuery, isExpanded);
  }

  // Render results
  function renderResults(originalQuery, showAll) {
    // Render conversations
    if (fullResults.conversations.length > 0) {
      conversationsSection.classList.remove('hidden');
      conversationsCount.textContent = fullResults.conversations.length;

      const itemsToShow = showAll ? fullResults.conversations : fullResults.conversations.slice(0, PREVIEW_LIMIT);
      conversationsResults.innerHTML = itemsToShow.map(conv => {
        const slug = conv.id.replace(/^ro\/[^/]+\//, '').replace('.md', '');
        const denomination = conv.data.denomination;
        const denominationLabel = denominationLabels[denomination] || denomination;

        return `
          <a href="/conversatii/${denomination}/${slug}" class="result-card block group bg-white hover:bg-primary/5 rounded-2xl p-5 shadow-md hover:shadow-xl border border-gray-100 hover:border-primary/30 transition-all">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center group-hover:bg-primary/20 transition-colors">
                <span class="material-symbols-outlined text-2xl text-primary">forum</span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-bold text-primary/70 uppercase tracking-wider mb-1">${denominationLabel}</p>
                <p class="text-base font-bold text-gray-900 leading-snug group-hover:text-primary transition-colors">${highlightMatch(conv.data.title, originalQuery)}</p>
              </div>
              <span class="material-symbols-outlined text-gray-400 group-hover:text-primary group-hover:translate-x-1 transition-all">arrow_forward</span>
            </div>
          </a>
        `;
      }).join('');

      showMoreConversationsBtn.classList.toggle('hidden', fullResults.conversations.length <= PREVIEW_LIMIT || showAll);
    } else {
      conversationsSection.classList.add('hidden');
    }

    // Render teme
    if (fullResults.teme.length > 0) {
      temeSection.classList.remove('hidden');
      temeCount.textContent = fullResults.teme.length;

      const itemsToShow = showAll ? fullResults.teme : fullResults.teme.slice(0, PREVIEW_LIMIT);
      temeResults.innerHTML = itemsToShow.map(tema => {
        const slug = tema.id.replace('.md', '');
        return `
          <a href="/teme/${slug}" class="result-card block group bg-white hover:bg-primary/5 rounded-2xl p-5 shadow-md hover:shadow-xl border border-gray-100 hover:border-primary/30 transition-all">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center group-hover:bg-primary/20 transition-colors">
                <span class="material-symbols-outlined text-2xl text-primary">auto_stories</span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-base font-bold text-gray-900 leading-snug mb-1 group-hover:text-primary transition-colors">${highlightMatch(tema.data.title, originalQuery)}</p>
                <p class="text-sm text-gray-600 line-clamp-2">${highlightMatch(tema.data.summary, originalQuery)}</p>
              </div>
              <span class="material-symbols-outlined text-gray-400 group-hover:text-primary group-hover:translate-x-1 transition-all">arrow_forward</span>
            </div>
          </a>
        `;
      }).join('');

      showMoreTemeBtn.classList.toggle('hidden', fullResults.teme.length <= PREVIEW_LIMIT || showAll);
    } else {
      temeSection.classList.add('hidden');
    }

    // Render personalitati
    if (fullResults.personalitati.length > 0) {
      personalitatiSection.classList.remove('hidden');
      personalitatiCount.textContent = fullResults.personalitati.length;

      const itemsToShow = showAll ? fullResults.personalitati : fullResults.personalitati.slice(0, PREVIEW_LIMIT);
      personalitatiResults.innerHTML = itemsToShow.map(pers => {
        const slug = pers.id.replace('.md', '');
        return `
          <a href="/personalitati/${slug}" class="result-card block group bg-white hover:bg-primary/5 rounded-2xl p-5 shadow-md hover:shadow-xl border border-gray-100 hover:border-primary/30 transition-all">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 bg-cover bg-center rounded-xl border-2 border-gray-200 group-hover:border-primary/50 transition-colors" style="background-image: url('${pers.data.image}')"></div>
              <div class="flex-1 min-w-0">
                <p class="text-base font-bold text-gray-900 leading-snug group-hover:text-primary transition-colors">${highlightMatch(pers.data.name, originalQuery)}</p>
                <p class="text-sm text-gray-600 italic">${highlightMatch(pers.data.title, originalQuery)}</p>
              </div>
              <span class="material-symbols-outlined text-gray-400 group-hover:text-primary group-hover:translate-x-1 transition-all">arrow_forward</span>
            </div>
          </a>
        `;
      }).join('');

      showMorePersonalitatiBtn.classList.toggle('hidden', fullResults.personalitati.length <= PREVIEW_LIMIT || showAll);
    } else {
      personalitatiSection.classList.add('hidden');
    }

    // Render locuri
    if (fullResults.locuri.length > 0) {
      locuriSection.classList.remove('hidden');
      locuriCount.textContent = fullResults.locuri.length;

      const itemsToShow = showAll ? fullResults.locuri : fullResults.locuri.slice(0, PREVIEW_LIMIT);
      locuriResults.innerHTML = itemsToShow.map(loc => {
        const slug = loc.id.replace('.md', '');
        return `
          <a href="/locuri/${slug}" class="result-card block group bg-white hover:bg-primary/5 rounded-2xl p-5 shadow-md hover:shadow-xl border border-gray-100 hover:border-primary/30 transition-all">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center group-hover:bg-primary/20 transition-colors">
                <span class="material-symbols-outlined text-2xl text-primary">location_on</span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-base font-bold text-gray-900 leading-snug group-hover:text-primary transition-colors">${highlightMatch(loc.data.name, originalQuery)}</p>
                <p class="text-sm text-gray-600 italic">${highlightMatch(loc.data.title, originalQuery)}</p>
              </div>
              <span class="material-symbols-outlined text-gray-400 group-hover:text-primary group-hover:translate-x-1 transition-all">arrow_forward</span>
            </div>
          </a>
        `;
      }).join('');

      showMoreLocuriBtn.classList.toggle('hidden', fullResults.locuri.length <= PREVIEW_LIMIT || showAll);
    } else {
      locuriSection.classList.add('hidden');
    }
  }

  // Show more buttons
  showMoreConversationsBtn?.addEventListener('click', () => {
    isExpanded = true;
    renderResults(searchInput.value, true);
  });

  showMoreTemeBtn?.addEventListener('click', () => {
    isExpanded = true;
    renderResults(searchInput.value, true);
  });

  showMorePersonalitatiBtn?.addEventListener('click', () => {
    isExpanded = true;
    renderResults(searchInput.value, true);
  });

  showMoreLocuriBtn?.addEventListener('click', () => {
    isExpanded = true;
    renderResults(searchInput.value, true);
  });

  // Real-time search
  searchInput?.addEventListener('input', (e) => {
    isExpanded = false;
    performSearch(e.target.value);
  });

  // Navigate to first result on Enter
  searchInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      let firstResultUrl = null;

      if (fullResults.conversations.length > 0) {
        const conv = fullResults.conversations[0];
        const slug = conv.id.replace(/^ro\/[^/]+\//, '').replace('.md', '');
        firstResultUrl = `/conversatii/${conv.data.denomination}/${slug}`;
      } else if (fullResults.teme.length > 0) {
        const tema = fullResults.teme[0];
        firstResultUrl = `/teme/${tema.id.replace('.md', '')}`;
      } else if (fullResults.personalitati.length > 0) {
        const pers = fullResults.personalitati[0];
        firstResultUrl = `/personalitati/${pers.id.replace('.md', '')}`;
      } else if (fullResults.locuri.length > 0) {
        const loc = fullResults.locuri[0];
        firstResultUrl = `/locuri/${loc.id.replace('.md', '')}`;
      }

      if (firstResultUrl) {
        window.location.href = firstResultUrl;
      }
    }
  });
</script>
