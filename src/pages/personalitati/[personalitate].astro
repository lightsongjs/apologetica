---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { marked } from 'marked';
import { resolveWikiLinks } from '../../lib/wiki-links';

export async function getStaticPaths() {
  const personalitati = await getCollection('personalitati');
  return personalitati.map(p => ({
    params: { personalitate: p.id.replace('.md', '') },
    props: { personalitate: p }
  }));
}

const { personalitate } = Astro.props;
const { name, title, image } = personalitate.data;
const body = resolveWikiLinks(personalitate.body);

// Parse sections
const sections: Record<string, string> = {};
const sectionRegex = /## (.+?)\n([\s\S]*?)(?=\n## |\n---|$)/g;
let match;
while ((match = sectionRegex.exec(body)) !== null) {
  sections[match[1].trim()] = match[2].trim();
}

// Helper to parse timeline entries
function parseTimeline(content: string) {
  const entries: Array<{ title: string; description: string; link?: string }> = [];
  const entryRegex = /### (.+?)\n([\s\S]*?)(?=\n### |\Z)/g;
  let match;
  while ((match = entryRegex.exec(content)) !== null) {
    const rawTitle = match[1].trim();
    const description = match[2].trim();

    // Extract link from title if present
    const linkMatch = rawTitle.match(/\[([^\]]+)\]\(([^)]+)\)/);
    const cleanTitle = linkMatch ? linkMatch[1] : rawTitle;
    const link = linkMatch ? linkMatch[2] : undefined;

    entries.push({
      title: cleanTitle,
      description,
      link
    });
  }
  return entries;
}

// Helper to parse list items with bold titles
function parseListItems(content: string) {
  const items: Array<{ title: string; description: string; link?: string }> = [];
  const lines = content.split('\n\n');

  for (const block of lines) {
    const titleMatch = block.match(/^\*\*(.+?)\*\*/);
    if (titleMatch) {
      const title = titleMatch[1];
      const description = block.replace(/^\*\*(.+?)\*\*[^\n]*\n?/, '').trim();

      // Extract link from title if present
      const linkMatch = title.match(/\[([^\]]+)\]\(([^)]+)\)/);
      const cleanTitle = linkMatch ? linkMatch[1] : title;
      const link = linkMatch ? linkMatch[2] : undefined;

      items.push({ title: cleanTitle, description, link });
    } else if (block.startsWith('###')) {
      const titleMatch = block.match(/^### (.+?)\n/);
      if (titleMatch) {
        const rawTitle = titleMatch[1];
        const description = block.replace(/^### (.+?)\n/, '').trim();

        // Extract link from title if present
        const linkMatch = rawTitle.match(/\[([^\]]+)\]\(([^)]+)\)/);
        const cleanTitle = linkMatch ? linkMatch[1] : rawTitle;
        const link = linkMatch ? linkMatch[2] : undefined;

        items.push({ title: cleanTitle, description, link });
      }
    }
  }
  return items;
}

// Helper to parse scripture verses
function parseVerses(content: string) {
  const verses: Array<{ ref: string; text: string }> = [];
  const verseRegex = /\*\*(.+?)\*\* — [""](.+?)[""]?$/gm;
  let match;
  while ((match = verseRegex.exec(content)) !== null) {
    verses.push({
      ref: match[1].trim(),
      text: match[2].trim().replace(/[""]$/g, '')
    });
  }
  return verses;
}

const timelineEntries = sections['Timeline'] ? parseTimeline(sections['Timeline']) : [];
const sources = sections['Surse și scrieri'] ? parseListItems(sections['Surse și scrieri']) : [];
const contemporaries = sections['Contemporani și rude spirituale'] ? parseListItems(sections['Contemporani și rude spirituale']) : [];
// Handle both "Versete cheie" and "Versete cheie din epistolele sale"
const versesSection = sections['Versete cheie din epistolele sale'] || sections['Versete cheie'] || '';
const verses = versesSection ? parseVerses(versesSection) : [];
const versesTitle = sections['Versete cheie'] ? 'Versete cheie' : 'Citate din scrierile sale';
const significance = sections['Semnificație teologică și istorică'] ? parseListItems(sections['Semnificație teologică și istorică']) : [];
---

<Base title={name} backHref="/personalitati" activeNav="home">
  <!-- Profile Header -->
  <div class="flex flex-col items-center bg-gradient-to-b from-primary/5 to-transparent py-8 -mx-4 px-4 mb-6">
    <div class="relative group">
      <div
        class="bg-top bg-no-repeat aspect-square bg-cover rounded-full border-4 border-white shadow-lg h-32 w-32 mb-4"
        style={`background-image: url("${image}")`}
      />
      <div class="absolute bottom-4 right-1 bg-primary text-white p-1 rounded-full border-2 border-white">
        <span class="material-symbols-outlined text-sm">verified</span>
      </div>
    </div>
    <div class="flex flex-col items-center text-center">
      <h1 class="text-3xl font-extrabold leading-tight tracking-tight">{name}</h1>
      <p class="text-primary text-lg font-medium italic mt-1">{title}</p>
    </div>
  </div>

  <!-- Main Content -->
  <div class="space-y-8 pb-8">

    <!-- Bio Section -->
    {sections['Bio'] && (
      <section>
        <div class="flex items-center gap-2 mb-3">
          <span class="material-symbols-outlined text-primary">history_edu</span>
          <h2 class="text-xl font-bold">Biografie</h2>
        </div>
        <div class="bg-primary/5 p-4 rounded-xl border border-primary/10 prose prose-slate prose-sm max-w-none">
          <Fragment set:html={marked(sections['Bio'])} />
        </div>
      </section>
    )}

    <!-- Timeline Section -->
    {timelineEntries.length > 0 && (
      <section>
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-primary">timeline</span>
          <h2 class="text-xl font-bold">Cronologie</h2>
        </div>
        <div class="relative ml-3 border-l-2 border-primary/30 pl-6 space-y-6">
          {timelineEntries.map(entry => (
            <div class="relative">
              <div class="absolute -left-[31px] top-1 size-4 rounded-full bg-primary border-4 border-white"></div>
              <h4 class="font-bold text-primary">{entry.title}</h4>
              <div class="text-sm text-gray-600 prose prose-slate prose-sm max-w-none" set:html={marked(entry.description)} />
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Sources Section -->
    {sources.length > 0 && (
      <section>
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-primary">book</span>
          <h2 class="text-xl font-bold">Surse și scrieri</h2>
        </div>
        <div class="space-y-3">
          {sources.map(item => {
            const CardWrapper = item.link ? 'a' : 'div';
            return (
              <CardWrapper
                {...(item.link ? { href: item.link } : {})}
                class:list={[
                  "bg-white p-4 rounded-xl border border-gray-200 block",
                  item.link && "group hover:border-primary/40 transition-all shadow-sm hover:shadow-md"
                ]}
              >
                <div class="flex items-start gap-3">
                  <div class="flex-1">
                    <h4 class:list={[
                      "font-bold text-gray-900 mb-1",
                      item.link && "group-hover:text-primary transition-colors"
                    ]}>{item.title}</h4>
                    <div class="text-sm text-gray-600 prose prose-slate prose-sm max-w-none" set:html={marked(item.description)} />
                  </div>
                  {item.link && (
                    <span class="material-symbols-outlined text-primary/30 group-hover:text-primary group-hover:translate-x-1 transition-all flex-shrink-0">chevron_right</span>
                  )}
                </div>
              </CardWrapper>
            );
          })}
        </div>
      </section>
    )}

    <!-- Contemporaries Section -->
    {contemporaries.length > 0 && (
      <section>
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-primary">groups</span>
          <h2 class="text-xl font-bold">Contemporani</h2>
        </div>
        <div class="space-y-3">
          {contemporaries.map(item => {
            const CardWrapper = item.link ? 'a' : 'div';
            return (
              <CardWrapper
                {...(item.link ? { href: item.link } : {})}
                class:list={[
                  "bg-white p-4 rounded-xl border border-gray-200 block",
                  item.link && "group hover:border-primary/40 transition-all shadow-sm hover:shadow-md"
                ]}
              >
                <div class="flex items-start gap-3">
                  <div class="flex-1">
                    <h4 class:list={[
                      "font-bold text-gray-900 mb-1",
                      item.link && "group-hover:text-primary transition-colors"
                    ]}>{item.title}</h4>
                    <div class="text-sm text-gray-600 prose prose-slate prose-sm max-w-none" set:html={marked(item.description)} />
                  </div>
                  {item.link && (
                    <span class="material-symbols-outlined text-primary/30 group-hover:text-primary group-hover:translate-x-1 transition-all flex-shrink-0">chevron_right</span>
                  )}
                </div>
              </CardWrapper>
            );
          })}
        </div>
      </section>
    )}

    <!-- Quotes Section -->
    {verses.length > 0 && (
      <section>
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-primary">menu_book</span>
          <h2 class="text-xl font-bold">{versesTitle}</h2>
        </div>
        <div class="space-y-3">
          {verses.map(verse => (
            <div class="bg-primary/5 p-4 rounded-xl border border-primary/10">
              <p class="text-sm italic text-gray-700 mb-2">"{verse.text}"</p>
              <cite class="text-xs font-bold text-primary not-italic">— {verse.ref}</cite>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Significance Section -->
    {significance.length > 0 && (
      <section>
        <div class="flex items-center gap-2 mb-3">
          <span class="material-symbols-outlined text-primary">auto_awesome</span>
          <h2 class="text-xl font-bold">Semnificație</h2>
        </div>
        <div class="space-y-4">
          {significance.map(item => {
            const CardWrapper = item.link ? 'a' : 'div';
            return (
              <CardWrapper
                {...(item.link ? { href: item.link } : {})}
                class:list={[
                  "bg-gray-50 p-4 rounded-xl block",
                  item.link && "group hover:bg-primary/5 transition-all"
                ]}
              >
                <div class="flex items-start gap-3">
                  <div class="flex-1">
                    <h4 class:list={[
                      "font-bold text-sm uppercase tracking-wider text-primary mb-1",
                      item.link && "group-hover:text-primary transition-colors"
                    ]}>{item.title}</h4>
                    <div class="text-sm leading-relaxed prose prose-slate prose-sm max-w-none" set:html={marked(item.description)} />
                  </div>
                  {item.link && (
                    <span class="material-symbols-outlined text-primary/30 group-hover:text-primary group-hover:translate-x-1 transition-all flex-shrink-0">chevron_right</span>
                  )}
                </div>
              </CardWrapper>
            );
          })}
        </div>
      </section>
    )}

  </div>
</Base>
