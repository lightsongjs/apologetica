---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const conversations = await getCollection('conversations');
const teme = await getCollection('teme');
const personalitati = await getCollection('personalitati');
const locuri = await getCollection('locuri');

const stats = {
  conversations: conversations.length,
  teme: teme.length,
  personalitati: personalitati.length,
  locuri: locuri.length,
};
---

<Base title="Apologetica" isHomePage={true}>
  <!-- Hero Section - Compact -->
  <div class="relative py-6">
    <!-- Background Decoration -->
    <div class="absolute inset-0 -mx-4 bg-gradient-to-br from-amber-50/40 via-transparent to-blue-50/40 rounded-2xl -z-10"></div>

    <div class="text-center space-y-4">
      <!-- Title & Search Bar Combined -->
      <div class="opacity-0" style="animation: fadeSlideIn 0.6s ease-out 0.1s forwards;">
        <div class="flex items-center justify-center gap-2 mb-3">
          <span class="material-symbols-outlined text-3xl text-primary">auto_stories</span>
          <h1 class="text-2xl md:text-3xl font-bold text-gray-900" style="font-family: 'Newsreader', serif;">
            Apologetică Ortodoxă
          </h1>
        </div>

        <!-- Hero Search Bar - Compact -->
        <button
          id="hero-search-btn"
          class="w-full group relative max-w-2xl mx-auto"
        >
          <div class="relative bg-white rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-200 hover:border-primary/30">
            <div class="flex items-center gap-3 p-3">
              <div class="flex-shrink-0 w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center group-hover:bg-primary/20 transition-colors">
                <span class="material-symbols-outlined text-xl text-primary">search</span>
              </div>
              <div class="flex-1 text-left">
                <p class="text-base text-gray-400 group-hover:text-gray-600 transition-colors">
                  Caută conversații, teme, personalități...
                </p>
              </div>
              <kbd class="hidden md:inline-block px-2 py-1 text-xs bg-gray-50 rounded border border-gray-200 text-gray-500">/</kbd>
            </div>
          </div>
        </button>
      </div>

      <!-- Stats Row - Compact -->
      <div class="grid grid-cols-4 gap-2 max-w-2xl mx-auto opacity-0" style="animation: fadeSlideIn 0.6s ease-out 0.2s forwards;">
        <div class="bg-white/80 rounded-lg p-2 border border-gray-100">
          <div class="text-xl font-bold text-primary" style="font-family: 'Newsreader', serif;">{stats.conversations}</div>
          <div class="text-[10px] text-gray-600 uppercase tracking-wide font-semibold">Conversații</div>
        </div>
        <div class="bg-white/80 rounded-lg p-2 border border-gray-100">
          <div class="text-xl font-bold text-primary" style="font-family: 'Newsreader', serif;">{stats.teme}</div>
          <div class="text-[10px] text-gray-600 uppercase tracking-wide font-semibold">Teme</div>
        </div>
        <div class="bg-white/80 rounded-lg p-2 border border-gray-100">
          <div class="text-xl font-bold text-primary" style="font-family: 'Newsreader', serif;">{stats.personalitati}</div>
          <div class="text-[10px] text-gray-600 uppercase tracking-wide font-semibold">Personalități</div>
        </div>
        <div class="bg-white/80 rounded-lg p-2 border border-gray-100">
          <div class="text-xl font-bold text-primary" style="font-family: 'Newsreader', serif;">{stats.locuri}</div>
          <div class="text-[10px] text-gray-600 uppercase tracking-wide font-semibold">Locuri</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Sections Grid - Compact -->
  <div class="mt-4 grid grid-cols-2 md:grid-cols-4 gap-3 opacity-0" style="animation: fadeSlideIn 0.6s ease-out 0.3s forwards;">

    <!-- Conversations - Featured -->
    <a
      href="/conversatii"
      class="col-span-2 group bg-gradient-to-br from-primary/5 via-white to-blue-50/30 rounded-xl border border-primary/10 hover:border-primary/30 transition-all shadow hover:shadow-lg"
    >
      <div class="p-4">
        <div class="flex items-center gap-3 mb-2">
          <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center group-hover:bg-primary transition-colors">
            <span class="material-symbols-outlined text-xl text-primary group-hover:text-white transition-colors">forum</span>
          </div>
          <h3 class="text-lg font-bold text-gray-900 group-hover:text-primary transition-colors" style="font-family: 'Newsreader', serif;">
            "Vorbesc cu un..."
          </h3>
        </div>
        <p class="text-sm text-gray-600 leading-snug">
          Răspunsuri pentru conversații cu atei, baptiști și alții
        </p>
      </div>
    </a>

    <!-- Teme -->
    <a
      href="/teme"
      class="group bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-all shadow hover:shadow-lg"
    >
      <div class="p-4">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center mb-2 group-hover:bg-primary group-hover:scale-105 transition-all">
          <span class="material-symbols-outlined text-xl text-primary group-hover:text-white transition-colors">auto_stories</span>
        </div>
        <h3 class="text-base font-bold text-gray-900 mb-1 group-hover:text-primary transition-colors" style="font-family: 'Newsreader', serif;">
          Teme
        </h3>
        <p class="text-xs text-gray-600 leading-tight">
          Doctrine ortodoxe
        </p>
      </div>
    </a>

    <!-- Personalități -->
    <a
      href="/personalitati"
      class="group bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-all shadow hover:shadow-lg"
    >
      <div class="p-4">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center mb-2 group-hover:bg-primary group-hover:scale-105 transition-all">
          <span class="material-symbols-outlined text-xl text-primary group-hover:text-white transition-colors">person_pin</span>
        </div>
        <h3 class="text-base font-bold text-gray-900 mb-1 group-hover:text-primary transition-colors" style="font-family: 'Newsreader', serif;">
          Personalități
        </h3>
        <p class="text-xs text-gray-600 leading-tight">
          Sfinți și apologeți
        </p>
      </div>
    </a>

    <!-- Locuri -->
    <a
      href="/locuri"
      class="group bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-all shadow hover:shadow-lg"
    >
      <div class="p-4">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center mb-2 group-hover:bg-primary group-hover:scale-105 transition-all">
          <span class="material-symbols-outlined text-xl text-primary group-hover:text-white transition-colors">location_on</span>
        </div>
        <h3 class="text-base font-bold text-gray-900 mb-1 group-hover:text-primary transition-colors" style="font-family: 'Newsreader', serif;">
          Locuri
        </h3>
        <p class="text-xs text-gray-600 leading-tight">
          Geografia biblică
        </p>
      </div>
    </a>

    <!-- Biblia placeholder -->
    <a
      href="#"
      class="group bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-all shadow hover:shadow-lg"
    >
      <div class="p-4">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center mb-2 group-hover:bg-primary group-hover:scale-105 transition-all">
          <span class="material-symbols-outlined text-xl text-primary group-hover:text-white transition-colors">menu_book</span>
        </div>
        <h3 class="text-base font-bold text-gray-900 mb-1 group-hover:text-primary transition-colors" style="font-family: 'Newsreader', serif;">
          Biblia
        </h3>
        <p class="text-xs text-gray-600 leading-tight">
          Exegeză și context
        </p>
      </div>
    </a>

  </div>

  <style>
    @keyframes fadeSlideIn {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Enhanced shadow for hero search */
    .shadow-3xl {
      box-shadow: 0 25px 50px -12px rgba(23, 84, 207, 0.15);
    }
  </style>

  <script>
    // Connect hero search button to search overlay
    const heroSearchBtn = document.getElementById('hero-search-btn');
    const floatingSearchBtn = document.getElementById('floating-search-btn');

    heroSearchBtn?.addEventListener('click', () => {
      floatingSearchBtn?.click();
    });

    // Also trigger on "/" key (handled by FloatingSearch, but we can enhance focus)
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement?.tagName !== 'INPUT') {
        e.preventDefault();
        floatingSearchBtn?.click();
      }
    });
  </script>
</Base>
