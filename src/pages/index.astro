---
import Base from '../layouts/Base.astro';
---

<Base title="Apologetica" activeNav="home">
  <!-- Cards -->
  <div class="space-y-3 pt-4">

    <!-- I'm talking with... -->
    <a class="block group" href="/conversatii">
      <div class="bg-white border border-primary/10 rounded-xl p-3 shadow-sm hover:shadow-md hover:border-primary/40 transition-all flex items-center gap-3">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-colors flex-shrink-0">
          <span class="material-symbols-outlined text-xl">forum</span>
        </div>
        <div class="flex-1 min-w-0">
          <h4 class="font-bold text-base mb-0.5 group-hover:text-primary transition-colors italic">"Vorbesc cu un..."</h4>
          <p class="text-xs text-primary/60 leading-tight">Răspunsuri pentru conversații dificile</p>
        </div>
        <span class="material-symbols-outlined text-primary/30 group-hover:translate-x-1 transition-transform flex-shrink-0">chevron_right</span>
      </div>
    </a>

    <!-- Grid -->
    <div class="grid grid-cols-2 gap-3">
      <a class="group bg-white rounded-xl p-3 border border-primary/10 hover:border-primary/40 transition-all shadow-sm flex flex-col" href="/teme">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center text-primary mb-2 group-hover:bg-primary group-hover:text-white transition-colors">
          <span class="material-symbols-outlined text-xl">auto_stories</span>
        </div>
        <h4 class="font-bold text-base mb-0.5">Teme</h4>
        <p class="text-xs text-primary/60 leading-tight">Subiecte teologice</p>
      </a>

      <a class="group bg-white rounded-xl p-3 border border-primary/10 hover:border-primary/40 transition-all shadow-sm flex flex-col" href="#">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center text-primary mb-2 group-hover:bg-primary group-hover:text-white transition-colors">
          <span class="material-symbols-outlined text-xl">menu_book</span>
        </div>
        <h4 class="font-bold text-base mb-0.5">Biblia</h4>
        <p class="text-xs text-primary/60 leading-tight">Exegeză și context</p>
      </a>

      <a class="group bg-white rounded-xl p-3 border border-primary/10 hover:border-primary/40 transition-all shadow-sm flex flex-col" href="/personalitati">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center text-primary mb-2 group-hover:bg-primary group-hover:text-white transition-colors">
          <span class="material-symbols-outlined text-xl">person_pin</span>
        </div>
        <h4 class="font-bold text-base mb-0.5">Personalități</h4>
        <p class="text-xs text-primary/60 leading-tight">Viața apologeților</p>
      </a>

      <a class="group bg-white rounded-xl p-3 border border-primary/10 hover:border-primary/40 transition-all shadow-sm flex flex-col" href="/locuri">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center text-primary mb-2 group-hover:bg-primary group-hover:text-white transition-colors">
          <span class="material-symbols-outlined text-xl">map</span>
        </div>
        <h4 class="font-bold text-base mb-0.5">Locuri</h4>
        <p class="text-xs text-primary/60 leading-tight">Locuri biblice</p>
      </a>
    </div>
  </div>
</Base>
