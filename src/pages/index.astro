---
import Base from '../layouts/Base.astro';
---

<Base title="Apologetica" activeNav="home">
  <!-- Cards -->
  <div class="space-y-4 pt-6">

    <!-- I'm talking with... -->
    <a class="block group" href="/conversatii">
      <div class="bg-white border border-primary/10 rounded-xl p-5 shadow-sm hover:shadow-md hover:border-primary/40 transition-all flex items-center gap-4">
        <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-colors">
          <span class="material-symbols-outlined">forum</span>
        </div>
        <div class="flex-1">
          <h4 class="font-bold text-xl mb-0.5 group-hover:text-primary transition-colors italic">"Vorbesc cu un..."</h4>
          <p class="text-sm text-primary/60 leading-relaxed">Răspunsuri ghidate pentru conversații dificile.</p>
        </div>
        <span class="material-symbols-outlined text-primary/30 group-hover:translate-x-1 transition-transform">chevron_right</span>
      </div>
    </a>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <a class="group bg-white rounded-xl p-5 border border-primary/10 hover:border-primary/40 transition-all shadow-sm" href="/teme">
        <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center text-primary mb-4 group-hover:bg-primary group-hover:text-white transition-colors">
          <span class="material-symbols-outlined">auto_stories</span>
        </div>
        <h4 class="font-bold text-xl mb-1">Teme</h4>
        <p class="text-sm text-primary/60 leading-relaxed">Subiecte teologice sistematice și dezbateri.</p>
      </a>

      <a class="group bg-white rounded-xl p-5 border border-primary/10 hover:border-primary/40 transition-all shadow-sm" href="#">
        <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center text-primary mb-4 group-hover:bg-primary group-hover:text-white transition-colors">
          <span class="material-symbols-outlined">menu_book</span>
        </div>
        <h4 class="font-bold text-xl mb-1">Biblia</h4>
        <p class="text-sm text-primary/60 leading-relaxed">Exegeză, context și dovezi din manuscrise.</p>
      </a>

      <a class="group bg-white rounded-xl p-5 border border-primary/10 hover:border-primary/40 transition-all shadow-sm" href="/personalitati">
        <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center text-primary mb-4 group-hover:bg-primary group-hover:text-white transition-colors">
          <span class="material-symbols-outlined">person_pin</span>
        </div>
        <h4 class="font-bold text-xl mb-1">Personalități</h4>
        <p class="text-sm text-primary/60 leading-relaxed">Viața și opera apologeților.</p>
      </a>

      <a class="group bg-white rounded-xl p-5 border border-primary/10 hover:border-primary/40 transition-all shadow-sm" href="/locuri">
        <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center text-primary mb-4 group-hover:bg-primary group-hover:text-white transition-colors">
          <span class="material-symbols-outlined">map</span>
        </div>
        <h4 class="font-bold text-xl mb-1">Locuri</h4>
        <p class="text-sm text-primary/60 leading-relaxed">Locuri biblice și semnificația lor istorică.</p>
      </a>
    </div>
  </div>

  <!-- Quote -->
  <div class="mt-12 p-8 border-t-2 border-primary/5 text-center italic">
    <span class="material-symbols-outlined text-primary/20 text-4xl block mb-2">format_quote</span>
    <p class="text-primary/70 text-lg leading-relaxed">
      "Rațiunea este o revelație naturală, prin care veșnicul Părinte al luminii... comunică omenirii acea porțiune de adevăr pe care a pus-o la îndemâna facultăților lor naturale."
    </p>
    <cite class="not-italic block mt-4 font-bold text-primary text-sm uppercase tracking-widest">— John Locke</cite>
  </div>
</Base>
