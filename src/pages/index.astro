---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const conversations = await getCollection('conversations');
const teme = await getCollection('teme');
const personalitati = await getCollection('personalitati');
const locuri = await getCollection('locuri');

const stats = {
  conversations: conversations.length,
  teme: teme.length,
  personalitati: personalitati.length,
  locuri: locuri.length,
};

const denominationLabels: Record<string, string> = {
  'atheist': 'Ateu',
  'baptist': 'Baptist',
  'martorii-lui-iehova': 'Martor al lui Iehova',
};
---

<Base title="Apologetica" isHomePage={true}>
  <!-- Hero Section - Compact -->
  <div class="relative py-6">
    <!-- Background Decoration -->
    <div class="absolute inset-0 -mx-4 bg-gradient-to-br from-amber-50/40 via-transparent to-blue-50/40 rounded-2xl -z-10"></div>

    <div class="text-center space-y-4">
      <!-- Inline Search Bar -->
      <div class="opacity-0" style="animation: fadeSlideIn 0.6s ease-out 0.1s forwards;">
        <div class="relative max-w-2xl mx-auto">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-primary/40 text-xl">search</span>
          <input
            type="text"
            id="home-search-input"
            placeholder="Caută conversații, teme, personalități..."
            class="w-full pl-12 pr-10 py-3.5 rounded-xl border border-gray-200 bg-white shadow-lg focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-all text-sm"
            autocomplete="off"
          />
          <kbd class="hidden md:inline-block absolute right-3 top-1/2 -translate-y-1/2 px-2 py-1 text-xs bg-gray-50 rounded border border-gray-200 text-gray-500">/</kbd>
        </div>
      </div>

      <!-- Stats Row - Compact -->
      <div id="stats-row" class="grid grid-cols-4 gap-2 max-w-2xl mx-auto opacity-0" style="animation: fadeSlideIn 0.6s ease-out 0.2s forwards;">
        <div class="bg-white/80 rounded-lg p-2 border border-gray-100">
          <div class="text-xl font-bold text-primary" style="font-family: 'Literata', serif;">{stats.conversations}</div>
          <div class="text-[10px] text-gray-600 uppercase tracking-wide font-semibold">Conversații</div>
        </div>
        <div class="bg-white/80 rounded-lg p-2 border border-gray-100">
          <div class="text-xl font-bold text-primary" style="font-family: 'Literata', serif;">{stats.teme}</div>
          <div class="text-[10px] text-gray-600 uppercase tracking-wide font-semibold">Teme</div>
        </div>
        <div class="bg-white/80 rounded-lg p-2 border border-gray-100">
          <div class="text-xl font-bold text-primary" style="font-family: 'Literata', serif;">{stats.personalitati}</div>
          <div class="text-[10px] text-gray-600 uppercase tracking-wide font-semibold">Personalități</div>
        </div>
        <div class="bg-white/80 rounded-lg p-2 border border-gray-100">
          <div class="text-xl font-bold text-primary" style="font-family: 'Literata', serif;">{stats.locuri}</div>
          <div class="text-[10px] text-gray-600 uppercase tracking-wide font-semibold">Locuri</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Sections Grid - Compact -->
  <div id="sections-grid" class="mt-4 grid grid-cols-2 md:grid-cols-4 gap-3 opacity-0" style="animation: fadeSlideIn 0.6s ease-out 0.3s forwards;">

    <!-- Conversations - Featured -->
    <a
      href="/conversatii"
      class="col-span-2 group bg-gradient-to-br from-primary/5 via-white to-blue-50/30 rounded-xl border border-primary/10 hover:border-primary/30 transition-all shadow hover:shadow-lg"
    >
      <div class="p-4">
        <div class="flex items-center gap-3 mb-2">
          <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center group-hover:bg-primary transition-colors">
            <span class="material-symbols-outlined text-xl text-primary group-hover:text-white transition-colors">forum</span>
          </div>
          <h3 class="text-lg font-bold text-gray-900 group-hover:text-primary transition-colors" style="font-family: 'Literata', serif;">
            "Vorbesc cu un..."
          </h3>
        </div>
        <p class="text-sm text-gray-600 leading-snug">
          Răspunsuri pentru conversații cu atei, baptiști și alții
        </p>
      </div>
    </a>

    <!-- Teme -->
    <a
      href="/teme"
      class="group bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-all shadow hover:shadow-lg"
    >
      <div class="p-4">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center mb-2 group-hover:bg-primary group-hover:scale-105 transition-all">
          <span class="material-symbols-outlined text-xl text-primary group-hover:text-white transition-colors">auto_stories</span>
        </div>
        <h3 class="text-base font-bold text-gray-900 mb-1 group-hover:text-primary transition-colors" style="font-family: 'Literata', serif;">
          Teme
        </h3>
        <p class="text-xs text-gray-600 leading-tight">
          Doctrine ortodoxe
        </p>
      </div>
    </a>

    <!-- Personalități -->
    <a
      href="/personalitati"
      class="group bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-all shadow hover:shadow-lg"
    >
      <div class="p-4">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center mb-2 group-hover:bg-primary group-hover:scale-105 transition-all">
          <span class="material-symbols-outlined text-xl text-primary group-hover:text-white transition-colors">person_pin</span>
        </div>
        <h3 class="text-base font-bold text-gray-900 mb-1 group-hover:text-primary transition-colors" style="font-family: 'Literata', serif;">
          Personalități
        </h3>
        <p class="text-xs text-gray-600 leading-tight">
          Sfinți și apologeți
        </p>
      </div>
    </a>

    <!-- Locuri -->
    <a
      href="/locuri"
      class="group bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-all shadow hover:shadow-lg"
    >
      <div class="p-4">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center mb-2 group-hover:bg-primary group-hover:scale-105 transition-all">
          <span class="material-symbols-outlined text-xl text-primary group-hover:text-white transition-colors">location_on</span>
        </div>
        <h3 class="text-base font-bold text-gray-900 mb-1 group-hover:text-primary transition-colors" style="font-family: 'Literata', serif;">
          Locuri
        </h3>
        <p class="text-xs text-gray-600 leading-tight">
          Geografia biblică
        </p>
      </div>
    </a>

    <!-- Biblia placeholder -->
    <a
      href="#"
      class="group bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-all shadow hover:shadow-lg"
    >
      <div class="p-4">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center mb-2 group-hover:bg-primary group-hover:scale-105 transition-all">
          <span class="material-symbols-outlined text-xl text-primary group-hover:text-white transition-colors">menu_book</span>
        </div>
        <h3 class="text-base font-bold text-gray-900 mb-1 group-hover:text-primary transition-colors" style="font-family: 'Literata', serif;">
          Biblia
        </h3>
        <p class="text-xs text-gray-600 leading-tight">
          Exegeză și context
        </p>
      </div>
    </a>

  </div>

  <!-- Search Results (hidden by default) -->
  <div id="search-results" class="mt-4 hidden">
    <div id="search-results-list" class="grid grid-cols-1 gap-2"></div>
  </div>

  <!-- No Results -->
  <div id="no-results" class="hidden text-center py-12">
    <span class="material-symbols-outlined text-primary/20 text-5xl mb-3">search_off</span>
    <p class="text-sm text-gray-500">Niciun rezultat găsit</p>
  </div>

  <style>
    @keyframes fadeSlideIn {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>

  <script define:vars={{ conversations, teme, personalitati, locuri, denominationLabels }}>
    const searchInput = document.getElementById('home-search-input');
    const sectionsGrid = document.getElementById('sections-grid');
    const statsRow = document.getElementById('stats-row');
    const searchResults = document.getElementById('search-results');
    const searchResultsList = document.getElementById('search-results-list');
    const noResultsEl = document.getElementById('no-results');

    function removeDiacritics(str) {
      return str
        .replace(/[ăâ]/g, 'a').replace(/[ĂÂ]/g, 'A')
        .replace(/[îï]/g, 'i').replace(/[ÎÏ]/g, 'I')
        .replace(/[șş]/g, 's').replace(/[ȘŞ]/g, 'S')
        .replace(/[țţ]/g, 't').replace(/[ȚŢ]/g, 'T');
    }

    function normalize(str) {
      return removeDiacritics(str.toLowerCase());
    }

    function highlightMatch(text, query) {
      if (!query) return text;
      const nq = normalize(query);
      let pattern = '';
      for (const ch of nq) {
        if (ch === 'a') pattern += '[aăâĂÂ]';
        else if (ch === 'i') pattern += '[iîïÎÏ]';
        else if (ch === 's') pattern += '[sșşȘŞ]';
        else if (ch === 't') pattern += '[tțţȚŢ]';
        else pattern += ch.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      }
      const regex = new RegExp(`(${pattern})`, 'gi');
      return text.replace(regex, '<mark class="bg-primary/20 text-primary font-bold px-0.5 rounded">$1</mark>');
    }

    function performSearch(query) {
      const q = normalize(query.trim());

      if (!q) {
        sectionsGrid.classList.remove('hidden');
        statsRow.classList.remove('hidden');
        searchResults.classList.add('hidden');
        noResultsEl.classList.add('hidden');
        return;
      }

      sectionsGrid.classList.add('hidden');
      statsRow.classList.add('hidden');

      const results = [];

      conversations.forEach(conv => {
        const denomLabel = denominationLabels[conv.data.denomination] || conv.data.denomination;
        if (normalize(conv.data.title).includes(q) || normalize(denomLabel).includes(q)) {
          const slug = conv.id.replace(/^ro\/[^/]+\//, '').replace('.md', '');
          results.push({
            icon: 'forum',
            label: denomLabel,
            title: conv.data.title,
            subtitle: null,
            href: '/conversatii/' + conv.data.denomination + '/' + slug,
          });
        }
      });

      teme.forEach(tema => {
        if (normalize(tema.data.title).includes(q) || normalize(tema.data.summary).includes(q)) {
          results.push({
            icon: 'auto_stories',
            label: null,
            title: tema.data.title,
            subtitle: tema.data.summary,
            href: '/teme/' + tema.id.replace('.md', ''),
          });
        }
      });

      personalitati.forEach(pers => {
        if (normalize(pers.data.name).includes(q) || normalize(pers.data.title).includes(q)) {
          results.push({
            icon: 'person_pin',
            label: null,
            title: pers.data.name,
            subtitle: pers.data.title,
            href: '/personalitati/' + pers.id.replace('.md', ''),
            image: pers.data.image,
          });
        }
      });

      locuri.forEach(loc => {
        if (normalize(loc.data.name).includes(q) || normalize(loc.data.title).includes(q)) {
          results.push({
            icon: 'location_on',
            label: null,
            title: loc.data.name,
            subtitle: loc.data.title,
            href: '/locuri/' + loc.id.replace('.md', ''),
          });
        }
      });

      if (results.length === 0) {
        searchResults.classList.add('hidden');
        noResultsEl.classList.remove('hidden');
        return;
      }

      noResultsEl.classList.add('hidden');
      searchResults.classList.remove('hidden');

      const oq = query.trim();
      searchResultsList.innerHTML = results.map(function(r) {
        var iconHtml = r.image
          ? '<div class="w-10 h-10 flex-shrink-0 bg-cover bg-center rounded-lg border border-gray-200 group-hover:border-primary/50 transition-colors" style="background-image: url(\'' + r.image + '\')"></div>'
          : '<div class="w-10 h-10 flex-shrink-0 bg-primary/10 rounded-lg flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all duration-300"><span class="material-symbols-outlined text-xl">' + r.icon + '</span></div>';

        var labelHtml = r.label
          ? '<span class="text-[10px] font-bold text-primary/70 uppercase tracking-wider">' + r.label + '</span>'
          : '';

        var subtitleHtml = r.subtitle
          ? '<p class="text-xs text-primary/60 truncate">' + highlightMatch(r.subtitle, oq) + '</p>'
          : '';

        return '<a href="' + r.href + '" class="group bg-white rounded-xl p-3 border border-primary/10 hover:border-primary/30 transition-all duration-300 shadow-sm hover:shadow-md flex items-center gap-3">'
          + iconHtml
          + '<div class="flex-1 min-w-0">'
          + labelHtml
          + '<h3 class="font-bold text-sm mb-0.5 group-hover:text-primary transition-colors" style="font-family: \'Literata\', serif;">' + highlightMatch(r.title, oq) + '</h3>'
          + subtitleHtml
          + '</div>'
          + '<span class="material-symbols-outlined text-lg text-primary/30 group-hover:translate-x-1 group-hover:text-primary transition-all duration-300 flex-shrink-0">chevron_right</span>'
          + '</a>';
      }).join('');
    }

    searchInput?.addEventListener('input', function(e) {
      performSearch(e.target.value);
    });

    searchInput?.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        var firstLink = searchResultsList?.querySelector('a');
        if (firstLink) {
          e.preventDefault();
          window.location.href = firstLink.getAttribute('href');
        }
      }
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === '/' && document.activeElement?.tagName !== 'INPUT') {
        e.preventDefault();
        searchInput?.focus();
      }
    });
  </script>
</Base>
