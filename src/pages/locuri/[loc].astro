---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { marked } from 'marked';
import { resolveWikiLinks } from '../../lib/wiki-links';

export async function getStaticPaths() {
  const locuri = await getCollection('locuri');
  return locuri.map(l => ({
    params: { loc: l.id.replace('.md', '') },
    props: { loc: l }
  }));
}

const { loc } = Astro.props;
const { name, title, image } = loc.data;
// Normalize line endings to \n (convert \r\n to \n)
const body = resolveWikiLinks(loc.body).replace(/\r\n/g, '\n');

// Parse sections - split by ## and parse
const sections: Record<string, string> = {};
const parts = body.split(/^## /gm);
for (let i = 1; i < parts.length; i++) {
  const part = parts[i];
  const firstNewline = part.indexOf('\n');
  if (firstNewline > 0) {
    const title = part.substring(0, firstNewline).trim();
    const content = part.substring(firstNewline + 1).trim();
    sections[title] = content;
  }
}

// Helper to parse timeline entries
function parseTimeline(content: string) {
  const entries: Array<{ title: string; description: string; link?: string }> = [];
  const entryRegex = /### (.+?)\n([\s\S]*?)(?=\n### |\Z)/g;
  let match;
  while ((match = entryRegex.exec(content)) !== null) {
    const rawTitle = match[1].trim();
    const description = match[2].trim();

    const linkMatch = rawTitle.match(/\[([^\]]+)\]\(([^)]+)\)/);
    const cleanTitle = linkMatch ? linkMatch[1] : rawTitle;
    const link = linkMatch ? linkMatch[2] : undefined;

    entries.push({ title: cleanTitle, description, link });
  }
  return entries;
}

// Helper to parse list items with bold titles
function parseListItems(content: string) {
  const items: Array<{ title: string; description: string; link?: string }> = [];

  // First, split by ### subsections
  const subsections = content.split(/^### /gm);

  for (let i = 0; i < subsections.length; i++) {
    const subsection = subsections[i];

    // If this is a subsection (starts with a title), extract the title as the first item
    if (i > 0) {
      const firstNewline = subsection.indexOf('\n');
      if (firstNewline > 0) {
        const subsectionTitle = subsection.substring(0, firstNewline).trim();
        const subsectionContent = subsection.substring(firstNewline + 1).trim();

        // Extract link from title if present (for display, but don't use it to wrap the whole card)
        const linkMatch = subsectionTitle.match(/\[([^\]]+)\]\(([^)]+)\)/);
        const cleanTitle = linkMatch ? linkMatch[1] : subsectionTitle;
        const link = linkMatch ? linkMatch[2] : undefined;

        // Only add the subsection as an item if it doesn't have **bold** children
        // (we'll parse those separately)
        if (!subsectionContent.includes('\n**')) {
          items.push({ title: cleanTitle, description: subsectionContent, link });
        }
      }
    }

    // Now find all **bold** items in this section/subsection
    const boldItemRegex = /\*\*([^\*]+?)\*\*\n([^\n*]*(?:\n(?!\*\*)[^\n*]*)*)/g;
    let match;
    while ((match = boldItemRegex.exec(subsection)) !== null) {
      const title = match[1].trim();
      const description = match[2].trim();

      // Extract link from title if present
      const linkMatch = title.match(/\[([^\]]+)\]\(([^)]+)\)/);
      const cleanTitle = linkMatch ? linkMatch[1] : title;
      const link = linkMatch ? linkMatch[2] : undefined;

      if (cleanTitle && description) {
        items.push({ title: cleanTitle, description, link });
      }
    }
  }

  return items;
}

// Helper to parse scripture verses
function parseVerses(content: string) {
  const verses: Array<{ ref: string; text: string }> = [];
  // Match both regular quotes and Romanian quotes („")
  const verseRegex = /\*\*(.+?)\*\* — ["""„](.+?)[""""]?$/gm;
  let match;
  while ((match = verseRegex.exec(content)) !== null) {
    verses.push({
      ref: match[1].trim(),
      text: match[2].trim().replace(/[""""]$/g, '')
    });
  }
  return verses;
}

const timelineEntries = sections['Evenimente biblice'] ? parseTimeline(sections['Evenimente biblice']) : [];
const sources = sections['Surse scripturistice'] ? parseListItems(sections['Surse scripturistice']) : [];
const personalities = sections['Personalități legate de acest loc'] ? parseListItems(sections['Personalități legate de acest loc']) : [];
const versesSection = sections['Versete cheie'] || '';
const verses = versesSection ? parseVerses(versesSection) : [];
const significance = sections['Semnificație teologică și istorică'] ? parseListItems(sections['Semnificație teologică și istorică']) : [];
---

<Base title={name} backHref="/locuri" activeNav="home">
  <!-- Profile Header -->
  <div class="flex flex-col items-center bg-gradient-to-b from-primary/5 to-transparent py-8 -mx-4 px-4 mb-6">
    <div class="relative group">
      <div
        class="bg-center bg-no-repeat aspect-square bg-cover rounded-xl border-4 border-white shadow-lg h-32 w-32 mb-4"
        style={`background-image: url("${image}")`}
      />
      <div class="absolute bottom-4 right-1 bg-primary text-white p-1 rounded-full border-2 border-white">
        <span class="material-symbols-outlined text-sm">place</span>
      </div>
    </div>
    <div class="flex flex-col items-center text-center">
      <h1 class="text-3xl font-extrabold leading-tight tracking-tight">{name}</h1>
      <p class="text-primary text-lg font-medium italic mt-1">{title}</p>
    </div>
  </div>

  <!-- Main Content -->
  <div class="space-y-8 pb-8">

    <!-- Description Section -->
    {sections['Descriere'] && (
      <section>
        <div class="flex items-center gap-2 mb-3">
          <span class="material-symbols-outlined text-primary">landscape</span>
          <h2 class="text-xl font-bold">Descriere</h2>
        </div>
        <div class="bg-primary/5 p-4 rounded-xl border border-primary/10 prose prose-slate prose-sm max-w-none">
          <Fragment set:html={marked(sections['Descriere'])} />
        </div>
      </section>
    )}

    <!-- Biblical Events Timeline -->
    {timelineEntries.length > 0 && (
      <section>
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-primary">timeline</span>
          <h2 class="text-xl font-bold">Evenimente biblice</h2>
        </div>
        <div class="relative ml-3 border-l-2 border-primary/30 pl-6 space-y-6">
          {timelineEntries.map(entry => (
            <div class="relative">
              <div class="absolute -left-[31px] top-1 size-4 rounded-full bg-primary border-4 border-white"></div>
              <h4 class="font-bold text-primary">{entry.title}</h4>
              <div class="text-sm text-gray-600 prose prose-slate prose-sm max-w-none" set:html={marked(entry.description)} />
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Sources Section -->
    {sources.length > 0 && (
      <section>
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-primary">book</span>
          <h2 class="text-xl font-bold">Surse scripturistice</h2>
        </div>
        <div class="space-y-3">
          {sources.map(item => (
            <div class="bg-white p-4 rounded-xl border border-gray-200 group hover:border-primary/40 transition-all shadow-sm hover:shadow-md">
              <div class="flex items-start gap-3">
                <div class="flex-1">
                  {item.link ? (
                    <a href={item.link} class="font-bold text-gray-900 mb-1 hover:text-primary transition-colors block">{item.title}</a>
                  ) : (
                    <h4 class="font-bold text-gray-900 mb-1">{item.title}</h4>
                  )}
                  <div class="text-sm text-gray-600 prose prose-slate prose-sm max-w-none" set:html={marked(item.description)} />
                </div>
                {item.link && (
                  <a href={item.link} class="material-symbols-outlined text-primary/30 group-hover:text-primary group-hover:translate-x-1 transition-all flex-shrink-0">chevron_right</a>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Personalities Section -->
    {personalities.length > 0 && (
      <section>
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-primary">groups</span>
          <h2 class="text-xl font-bold">Personalități</h2>
        </div>
        <div class="space-y-3">
          {personalities.map(item => (
            <div class="bg-white p-4 rounded-xl border border-gray-200 group hover:border-primary/40 transition-all shadow-sm hover:shadow-md">
              <div class="flex items-start gap-3">
                <div class="flex-1">
                  {item.link ? (
                    <a href={item.link} class="font-bold text-gray-900 mb-1 hover:text-primary transition-colors block">{item.title}</a>
                  ) : (
                    <h4 class="font-bold text-gray-900 mb-1">{item.title}</h4>
                  )}
                  <div class="text-sm text-gray-600 prose prose-slate prose-sm max-w-none" set:html={marked(item.description)} />
                </div>
                {item.link && (
                  <a href={item.link} class="material-symbols-outlined text-primary/30 group-hover:text-primary group-hover:translate-x-1 transition-all flex-shrink-0">chevron_right</a>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Verses Section -->
    {verses.length > 0 && (
      <section>
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-primary">menu_book</span>
          <h2 class="text-xl font-bold">Versete cheie</h2>
        </div>
        <div class="space-y-3">
          {verses.map(verse => (
            <div class="bg-primary/5 p-4 rounded-xl border border-primary/10">
              <p class="text-sm italic text-gray-700 mb-2">"{verse.text}"</p>
              <cite class="text-xs font-bold text-primary not-italic">— {verse.ref}</cite>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Significance Section -->
    {significance.length > 0 && (
      <section>
        <div class="flex items-center gap-2 mb-3">
          <span class="material-symbols-outlined text-primary">auto_awesome</span>
          <h2 class="text-xl font-bold">Semnificație</h2>
        </div>
        <div class="space-y-4">
          {significance.map(item => (
            <div class="bg-gray-50 p-4 rounded-xl group hover:bg-primary/5 transition-all">
              <div class="flex items-start gap-3">
                <div class="flex-1">
                  {item.link ? (
                    <a href={item.link} class="font-bold text-sm uppercase tracking-wider text-primary mb-1 hover:text-primary transition-colors block">{item.title}</a>
                  ) : (
                    <h4 class="font-bold text-sm uppercase tracking-wider text-primary mb-1">{item.title}</h4>
                  )}
                  <div class="text-sm leading-relaxed prose prose-slate prose-sm max-w-none" set:html={marked(item.description)} />
                </div>
                {item.link && (
                  <a href={item.link} class="material-symbols-outlined text-primary/30 group-hover:text-primary group-hover:translate-x-1 transition-all flex-shrink-0">chevron_right</a>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

  </div>
</Base>
