---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const teme = await getCollection('teme');
const sorted = teme.sort((a, b) => a.data.title.localeCompare(b.data.title, 'ro'));
---

<Base title="Teme" headerTitle="Teme" backHref="/" activeNav="home">
  <!-- Header -->
  <div class="mb-6 pt-4">
    <h1 class="text-3xl font-extrabold leading-tight tracking-tight mb-2">Teme apologetice</h1>
    <p class="text-primary/70 leading-relaxed">Subiecte teologice sistematice și dezbateri.</p>
  </div>

  <!-- Theme list -->
  <div class="grid grid-cols-1 gap-4">
    {sorted.map(tema => (
      <a
        href={`/teme/${tema.id}`}
        class="group bg-white rounded-xl p-4 border border-primary/10 hover:border-primary/40 transition-all shadow-sm hover:shadow-md flex items-center gap-4"
      >
        <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-colors flex-shrink-0">
          <span class="material-symbols-outlined">auto_stories</span>
        </div>
        <div class="flex-1">
          <h3 class="font-bold text-lg mb-0.5 group-hover:text-primary transition-colors">{tema.data.title}</h3>
          <p class="text-sm text-primary/60 leading-relaxed line-clamp-2">{tema.data.summary}</p>
        </div>
        <span class="material-symbols-outlined text-primary/30 group-hover:translate-x-1 transition-transform">chevron_right</span>
      </a>
    ))}
  </div>
</Base>
