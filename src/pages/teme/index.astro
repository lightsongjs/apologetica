---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const teme = await getCollection('teme');
const sorted = teme.sort((a, b) => a.data.title.localeCompare(b.data.title, 'ro'));
---

<Base title="Teme" headerTitle="Teme" backHref="/" activeNav="home">
  <!-- Search Bar -->
  <div class="mb-4 opacity-0" style="animation: fadeIn 0.4s ease-out forwards;">
    <div class="relative">
      <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-primary/40 text-xl">search</span>
      <input
        type="text"
        id="search-input"
        placeholder="Caută teme..."
        class="w-full pl-11 pr-4 py-3 rounded-xl border border-primary/20 bg-white focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-all text-sm"
      />
    </div>
  </div>

  <!-- Cards Grid -->
  <div id="cards-grid" class="grid grid-cols-1 gap-2">
    {sorted.map((tema, i) => (
      <a
        href={`/teme/${tema.id}`}
        class="item-card group bg-white rounded-xl p-3 border border-primary/10 hover:border-primary/30 transition-all duration-300 shadow-sm hover:shadow-md flex items-center gap-3 opacity-0"
        style={`animation: fadeIn 0.4s ease-out ${(i + 1) * 0.05}s forwards;`}
        data-title={tema.data.title.toLowerCase()}
        data-summary={tema.data.summary.toLowerCase()}
      >
        <!-- Icon -->
        <div class="w-10 h-10 flex-shrink-0 bg-primary/10 rounded-lg flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all duration-300">
          <span class="material-symbols-outlined text-xl">auto_stories</span>
        </div>

        <!-- Content -->
        <div class="flex-1 min-w-0">
          <h3 class="font-bold text-sm mb-0.5 group-hover:text-primary transition-colors" style="font-family: 'Literata', serif;">{tema.data.title}</h3>
          <p class="text-xs text-primary/60 truncate">{tema.data.summary}</p>
        </div>

        <!-- Chevron -->
        <span class="material-symbols-outlined text-lg text-primary/30 group-hover:translate-x-1 group-hover:text-primary transition-all duration-300 flex-shrink-0">chevron_right</span>
      </a>
    ))}
  </div>

  <!-- No Results -->
  <div id="no-results" class="hidden text-center py-12">
    <span class="material-symbols-outlined text-primary/20 text-5xl mb-3">search_off</span>
    <p class="text-sm text-gray-500">Nicio temă găsită</p>
  </div>

  <style>
    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>

  <script>
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const cards = document.querySelectorAll('.item-card') as NodeListOf<HTMLElement>;
    const noResults = document.getElementById('no-results') as HTMLElement;

    searchInput?.addEventListener('input', () => {
      const query = searchInput.value.toLowerCase().trim();
      let visibleCount = 0;

      cards.forEach(card => {
        const title = card.dataset.title || '';
        const summary = card.dataset.summary || '';

        if (title.includes(query) || summary.includes(query)) {
          card.style.display = 'flex';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      if (visibleCount === 0 && query !== '') {
        noResults.classList.remove('hidden');
      } else {
        noResults.classList.add('hidden');
      }
    });
  </script>
</Base>
