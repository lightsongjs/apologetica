---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { marked } from 'marked';
import { resolveWikiLinks } from '../../lib/wiki-links';
import RelatedContent from '../../components/RelatedContent.astro';

export async function getStaticPaths() {
  const allTeme = await getCollection('teme');

  return allTeme.map((tema) => ({
    params: { tema: tema.id },
    props: { entry: tema },
  }));
}

const { entry } = Astro.props;
const body = resolveWikiLinks(entry.body || '').replace(/\r\n/g, '\n');

// Parse sections
const sections: Record<string, string> = {};
const parts = body.split(/^## /gm);
for (let i = 1; i < parts.length; i++) {
  const part = parts[i];
  const firstNewline = part.indexOf('\n');
  if (firstNewline > 0) {
    const title = part.substring(0, firstNewline).trim();
    const content = part.substring(firstNewline + 1).trim();
    sections[title] = content;
  }
}

// Parse timeline/cronologie entries
function parseTimeline(content: string) {
  const entries: Array<{ title: string; description: string }> = [];
  const entryRegex = /### (.+?)\n([\s\S]*?)(?=\n### |$)/g;
  let match;
  while ((match = entryRegex.exec(content)) !== null) {
    entries.push({
      title: match[1].trim(),
      description: match[2].trim()
    });
  }
  return entries;
}

const cronologieEntries = sections['Cronologie'] ? parseTimeline(sections['Cronologie']) : [];

// Parse special sections for custom rendering
const prezentareGenerala = sections['Prezentare generală'] || null;
const autorContext = sections['Autor și context'] || null;
const structura = sections['Structură'] || null;
const personajePrincipale = sections['Personaje principale'] || null;
const temeTeo = sections['Teme teologice'] || null;
const verseteKey = sections['Versete cheie'] || null;
const tipologie = sections['Tipologie și profeții mesianice'] || null;
const importantaOrtodoxa = sections['Importanță în teologia ortodoxă'] || sections['Importanță teologică ortodoxă'] || null;
const lecturiLiturgice = sections['Lecturi liturgice'] || null;
const sfintiParinti = sections['Sfinți Părinți și Facerea'] || sections['Sfinți Părinți'] || null;

// Render body HTML excluding special sections (will render them separately)
let bodyToRender = body;
const specialSections = ['Prezentare generală', 'Autor și context', 'Structură', 'Personaje principale', 'Cronologie', 'Teme teologice', 'Versete cheie', 'Tipologie și profeții mesianice', 'Importanță în teologia ortodoxă', 'Importanță teologică ortodoxă', 'Lecturi liturgice', 'Sfinți Părinți și Facerea', 'Sfinți Părinți'];
for (const section of specialSections) {
  if (sections[section]) {
    bodyToRender = bodyToRender.replace(new RegExp(`## ${section}[\\s\\S]*?(?=\\n## |$)`), '');
  }
}
const bodyHtml = await marked.parse(bodyToRender);
---

<Base title={entry.data.title} headerTitle={entry.data.title} useHistoryBack={true} activeNav="home">
  <div class="pt-4 pb-8 space-y-6">

    <!-- Title & Summary -->
    <div class="text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold leading-tight tracking-tight">{entry.data.title}</h2>
      <p class="mt-3 text-base text-slate-500 leading-relaxed max-w-md mx-auto">{entry.data.summary}</p>
    </div>

    <!-- Prezentare generală (Card with icon) -->
    {prezentareGenerala && (
      <section class="bg-blue-50/50 rounded-2xl p-6 border border-slate-200">
        <div class="flex items-center gap-3 mb-4">
          <div class="bg-primary text-white p-2 rounded-lg">
            <span class="material-symbols-outlined text-2xl">info</span>
          </div>
          <h2 class="text-2xl font-bold text-slate-900">Prezentare generală</h2>
        </div>
        <div class="prose prose-slate prose-base max-w-none prose-p:leading-relaxed prose-p:text-slate-800 prose-strong:text-slate-900" set:html={marked(prezentareGenerala)} />
      </section>
    )}

    <!-- Autor și context (Compact card) -->
    {autorContext && (
      <section class="bg-white rounded-xl p-6 border border-slate-200 shadow-sm">
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-slate-600">person</span>
          <h2 class="text-xl font-bold text-slate-900">Autor și context</h2>
        </div>
        <div class="prose prose-slate prose-base max-w-none prose-p:leading-relaxed prose-p:text-slate-800" set:html={marked(autorContext)} />
      </section>
    )}

    <!-- Structură (Table card) -->
    {structura && (
      <section class="bg-slate-50/80 rounded-xl p-6 border border-slate-200">
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-slate-600">account_tree</span>
          <h2 class="text-xl font-bold text-slate-900">Structură</h2>
        </div>
        <div class="prose prose-slate prose-base max-w-none prose-table:text-sm prose-th:bg-white prose-th:text-left prose-th:text-slate-900 prose-th:font-bold prose-td:py-3 prose-td:text-slate-800" set:html={marked(structura)} />
      </section>
    )}

    <!-- Personaje principale -->
    {personajePrincipale && (
      <section class="bg-stone-50/50 rounded-xl p-6 border border-slate-200">
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-slate-600">groups</span>
          <h2 class="text-xl font-bold text-slate-900">Personaje principale</h2>
        </div>
        <div class="prose prose-slate prose-base max-w-none prose-ul:space-y-2 prose-li:leading-relaxed prose-li:text-slate-800 prose-h3:text-slate-900 prose-h3:text-lg prose-h3:mt-4 prose-h3:mb-2" set:html={marked(personajePrincipale)} />
      </section>
    )}

    <!-- Cronologie Section (Timeline style in card) -->
    {cronologieEntries.length > 0 && (
      <section class="bg-indigo-50/40 rounded-xl p-6 border border-slate-200">
        <div class="flex items-center gap-2 mb-5">
          <span class="material-symbols-outlined text-indigo-600">timeline</span>
          <h2 class="text-xl font-bold text-slate-900">Cronologie</h2>
        </div>
        <div class="relative ml-3 border-l-2 border-slate-300 pl-6 space-y-6">
          {cronologieEntries.map(entry => (
            <div class="relative">
              <div class="absolute -left-[31px] top-1 size-4 rounded-full bg-indigo-500 border-4 border-white"></div>
              <h4 class="font-bold text-slate-900">{entry.title}</h4>
              <div class="text-sm text-slate-700 prose prose-slate prose-base max-w-none" set:html={marked(entry.description)} />
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Teme teologice -->
    {temeTeo && (
      <section class="bg-violet-50/40 rounded-xl p-6 border border-slate-200">
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-violet-600">psychology</span>
          <h2 class="text-xl font-bold text-slate-900">Teme teologice</h2>
        </div>
        <div class="prose prose-slate prose-base max-w-none
          prose-h3:text-slate-900 prose-h3:text-base prose-h3:font-bold prose-h3:mt-0 prose-h3:mb-2
          prose-p:leading-relaxed prose-p:text-slate-800
          prose-ul:list-disc prose-ul:ml-5 prose-ul:space-y-2
          prose-li:text-slate-800"
          set:html={marked(temeTeo)} />
      </section>
    )}

    <!-- Versete cheie (Quote style) -->
    {verseteKey && (
      <section>
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-primary">format_quote</span>
          <h2 class="text-xl font-bold">Versete cheie</h2>
        </div>
        <div class="space-y-3 prose prose-slate prose-base max-w-none prose-p:bg-primary/5 prose-p:border-l-4 prose-p:border-primary prose-p:pl-4 prose-p:py-3 prose-p:rounded-r-lg prose-p:my-2" set:html={marked(verseteKey)} />
      </section>
    )}

    <!-- Tipologie -->
    {tipologie && (
      <section class="bg-amber-50/50 rounded-xl p-6 border border-slate-200">
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-amber-600">link</span>
          <h2 class="text-xl font-bold text-slate-900">Tipologie și profeții mesianice</h2>
        </div>
        <div class="prose prose-slate prose-base max-w-none prose-p:text-slate-800 prose-table:text-sm prose-th:bg-amber-50/30 prose-th:text-slate-900 prose-td:text-slate-800" set:html={marked(tipologie)} />
      </section>
    )}

    <!-- Importanță în teologia ortodoxă -->
    {importantaOrtodoxa && (
      <section class="bg-teal-50/40 rounded-xl p-6 border border-slate-200">
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-teal-600">church</span>
          <h2 class="text-xl font-bold text-slate-900">Importanță în teologia ortodoxă</h2>
        </div>
        <div class="prose prose-slate prose-base max-w-none
          prose-h3:text-slate-900 prose-h3:text-base prose-h3:font-bold
          prose-p:text-slate-800 prose-p:leading-relaxed
          prose-ul:list-disc prose-ul:ml-5
          prose-li:text-slate-800"
          set:html={marked(importantaOrtodoxa)} />
      </section>
    )}

    <!-- Lecturi liturgice -->
    {lecturiLiturgice && (
      <section class="bg-pink-50/40 rounded-xl p-6 border border-slate-200">
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-pink-600">auto_stories</span>
          <h2 class="text-xl font-bold text-slate-900">Lecturi liturgice</h2>
        </div>
        <div class="prose prose-slate prose-base max-w-none
          prose-p:text-slate-800
          prose-ul:list-disc prose-ul:ml-5
          prose-li:text-slate-800"
          set:html={marked(lecturiLiturgice)} />
      </section>
    )}

    <!-- Sfinți Părinți -->
    {sfintiParinti && (
      <section class="bg-sky-50/40 rounded-xl p-6 border border-slate-200">
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-sky-600">menu_book</span>
          <h2 class="text-xl font-bold text-slate-900">Sfinți Părinți</h2>
        </div>
        <div class="prose prose-slate prose-base max-w-none
          prose-p:text-slate-800
          prose-strong:text-slate-900"
          set:html={marked(sfintiParinti)} />
      </section>
    )}

    <!-- Rest of body content -->
    {bodyHtml && (
      <article class="prose prose-slate prose-base max-w-none
        prose-headings:text-primary prose-headings:font-bold
        prose-h2:text-xl prose-h2:mt-8 prose-h2:mb-3
        prose-h3:text-lg prose-h3:mt-6 prose-h3:mb-2
        prose-strong:text-slate-800
        prose-ul:space-y-1
        prose-p:leading-relaxed
        prose-li:leading-relaxed
        prose-table:text-base
        prose-th:text-left prose-th:text-primary prose-th:font-bold
        prose-td:py-2
        prose-blockquote:border-primary/30 prose-blockquote:text-slate-600 prose-blockquote:italic">
        <Fragment set:html={bodyHtml} />
      </article>
    )}

    <!-- Related Content -->
    <RelatedContent
      related={entry.data.related}
      opposed_to={entry.data.opposed_to}
      condemned_at={entry.data.condemned_at}
    />

  </div>
</Base>
